{
  "name": "kaloscope-frontend",
  "version": "0.0.1",
  "description": "Frontend for Kaloscope project",
  "author": "Xylitol <jam.xylitol@gmail.com>",
  "license": "GPL-3.0-or-later",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:icons": "tsx ./src/lib/icons/preload.ts && prettier --write ./src/lib/icons",
    "build:jsonc": "lezer-generator ./src/lib/grammars/jsonc.grammar -o ./src/lib/grammars/jsonc-parser.js",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@fontsource-variable/noto-sans-sc": "^5.2.9",
    "@fontsource/audiowide": "^5.2.7",
    "@fontsource/zcool-qingke-huangyou": "^5.2.8",
    "@xyflow/svelte": "^1.4.0",
    "cally": "^0.8.0",
    "codemirror": "^6.0.2",
    "cropperjs": "^2.1.0",
    "iconify-icon": "^3.0.1",
    "ky": "^1.13.0",
    "svelte-i18n": "^4.0.1",
    "sveltekit-search-params": "4.0.0-next.0",
    "tippy.js": "^6.3.7",
    "ua-parser-js": "^2.0.6",
    "uuid": "^13.0.0",
    "xgplayer": "^3.0.23",
    "xgplayer-flv": "^3.0.23",
    "xgplayer-hls": "^3.0.23",
    "xgplayer-mp4": "^3.0.23"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.0",
    "@lezer/generator": "^1.8.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.47.3",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.16",
    "@types/node": "^24.9.1",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vite-pwa/sveltekit": "^1.0.1",
    "daisyui": "^5.3.8",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.12.5",
    "globals": "^16.4.0",
    "license-checker": "^25.0.1",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "svelte": "^5.41.2",
    "svelte-check": "^4.3.3",
    "tailwindcss": "^4.1.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.12",
    "vite-plugin-devtools-json": "^1.0.0"
  }
}
