<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<episodedetails>
{% autoescape true %}
  <lockdata>{{ lockdata|default(true)|lower }}</lockdata>
  <uniqueid type="{{ site }}" default="true">{{ id }}</uniqueid>
  <title>{{ title }}</title>
  <plot>{{ plot }}</plot>
  <rating>{{ rating }}</rating>
  <aired>{{ aired }}</aired>
  <season>{{ season }}</season>
  <episode>{{ episode }}</episode>
  <art>
    <poster>{{ poster }}</poster>
  </art>
{% endautoescape %}
</episodedetails>
